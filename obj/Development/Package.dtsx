              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.IO;
using System.Diagnostics;
using Microsoft.SqlServer.Dts.Runtime;
#endregion

namespace ST_FinalFix
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            try
            {
                // 1. Variable uthana
                string inputPath = Dts.Variables["User::FileName"].Value.ToString();

                // 2. FFmpeg aur Paths set karna
                string ffmpegPath = @"C:\ffmpeg\bin\ffmpeg.exe"; // Ensure ye file exist karti ho!
                string outputFolder = @"E:\datathing\Refined_reel\";
                string fileName = Path.GetFileName(inputPath);
                string outputPath = Path.Combine(outputFolder, fileName);

                if (!Directory.Exists(outputFolder)) Directory.CreateDirectory(outputFolder);

                // 3. FFmpeg Process Setup
                ProcessStartInfo startInfo = new ProcessStartInfo
                {
                    FileName = ffmpegPath,
                    Arguments = $"-i \"{inputPath}\" -t 8 -c copy \"{outputPath}\" -y",
                    CreateNoWindow = true,
                    UseShellExecute = false,
                    WindowStyle = ProcessWindowStyle.Hidden
                };

                // 4. Execution
                using (Process exeProcess = Process.Start(startInfo))
                {
                    exeProcess.WaitForExit();
                }

                // 5. Result (Direct Integer use kar rahe hain taake XML error na aaye)
                Dts.TaskResult = 0; // 0 = Success
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Script Task Error", ex.Message, "", 0);
                Dts.TaskResult = 1; // 1 = Failure
            }
        }
    }
}]]></ProjectItem>
